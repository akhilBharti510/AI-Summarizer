# ─── Core ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=AI Summarizer
API_PREFIX=/api/v1

# ─── Database (Neon) ─────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── CORS ────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-me-with-64-random-bytes
JWT_REFRESH_SECRET=replace-me-with-a-different-64-random-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=90d

# ─── Cookies ─────────────────────────────────────────────
COOKIE_DOMAIN=
COOKIE_SECURE=false   # true in production behind HTTPS

# ─── Sessions (guest) ────────────────────────────────────
SESSION_SECRET=replace-me-with-32+-random-bytes

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/dashboard
OAUTH_FAILURE_REDIRECT=http://localhost:5173/login?error=oauth

# ─── Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Mail (forgot password) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AI Summarizer <no-reply@example.com>"
APP_URL=http://localhost:5173

# ─── Seed admin (first boot) ─────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!2025
ADMIN_NAME=Administrator

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN=

# ─── Uploads ─────────────────────────────────────────────
UPLOAD_MAX_MB=10
