# Local dev: Vite reads this when no .env is present.
# Production: set the same keys in Vercel → Project Settings → Environment Variables.

# Public API base URL — include the /api/v1 prefix.
# Local:       http://localhost:4000/api/v1
# Production:  https://your-api.up.railway.app/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# Toggle the "Continue with Google" button on the login page.
VITE_GOOGLE_OAUTH_ENABLED=true

# Optional. Sentry DSN for frontend error reporting.
VITE_SENTRY_DSN=
